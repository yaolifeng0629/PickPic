{
  "name": "PickPic",
  "displayName": "PickPic: One-click downloader for images and videos from any webpage",
  "version": "2.0.0",
  "description": "One-click downloader for images and videos from any webpage",
  "author": "dev@yaolifeng.com",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "file-saver": "^2.0.5",
    "i18next": "^25.6.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "mux.js": "^6.3.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-i18next": "^16.1.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "0.0.258",
    "@types/file-saver": "^2.0.7",
    "@types/node": "22.19.19",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.1",
    "typescript": "5.5.4",
    "vitest": "^4.1.6"
  },
  "manifest": {
    "name": "PickPic: One-click downloader for images and videos from any webpage",
    "description": "One-click downloader for images and videos from any webpage",
    "version": "2.0.0",
    "permissions": [
      "activeTab",
      "storage",
      "downloads",
      "sidePanel",
      "contextMenus"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "action": {
      "default_title": "PickPic: One-click downloader for images and videos from any webpage"
    },
    "side_panel": {
      "default_path": "sidepanel.html"
    },
    "icons": {
      "16": "/assets/icon16.png",
      "32": "/assets/icon32.png",
      "48": "/assets/icon48.png",
      "128": "/assets/icon128.png"
    },
    "web_accessible_resources": [
      {
        "resources": [
          "assets/*.{png,webp,gif,svg}"
        ],
        "matches": [
          "https://www.plasmo.com/*"
        ]
      }
    ]
  }
}
